{
  "name": "medusa-v1-backend",
  "version": "0.0.2",
  "description": "A Prebaked Medusa 1.20 backend",
  "author": "Rasmus Puls",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "echo \"Medusa V1 backend build skipped\"",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "ib": "init-backend",
    "start": "init-backend && medusa db:migrate && medusa start --verbose",
    "dev": "medusa develop",
    "email:dev": "email dev --dir=./src/modules/email-notifications/templates --port=3002"
  },
  "dependencies": {
    "@medusajs/framework": "1.0.0-rc-20241022152047",
    "@medusajs/medusa": "1.20.11",
    "@medusajs/event-bus-redis": "1.8.14",
    "@medusajs/file-local": "1.0.4",
    "@medusajs/notification-sendgrid": "1.0.0-rc-20241022152047",
    "@medusajs/payment-stripe": "1.0.0-rc-20241022152047",
    "@medusajs/workflow-engine-redis": "1.0.0-rc-20241022152047",
    "@react-email/components": "^1.0.12",
    "axios": "^1.16.0",
    "body-parser": "^2.2.2",
    "lucide-react": "^1.14.0",
    "medusajs-launch-utils": "0.0.18",
    "minio": "^8.0.7",
    "resend": "4.0.1",
    "ulid": "^2.4.0"
  },
  "devDependencies": {
    "@react-email/preview-server": "^5.2.10",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.39",
    "@types/body-parser": "^1.19.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^5.2.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.5.8",
      "protobufjs": "7.5.5"
    }
  },
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": "24.x"
  }
}
