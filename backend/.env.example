# ============================================
# Medusa 2.0 Backend - Environment Variables
# ============================================
# Copy this file to `.env` and fill in the values.
# Do NOT commit `.env` to git.

# --- Core ---
NODE_ENV=development
PORT=9000

# --- CORS ---
# Comma separated list of allowed origins.
# LOCAL dev defaults:
STORE_CORS=http://localhost:8000,http://localhost:3000
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:8000,http://localhost:7001,http://localhost:9000
# In production add your Railway URLs e.g.
# STORE_CORS=https://king-keys-storefront.up.railway.app
# ADMIN_CORS=https://king-keys-backend.up.railway.app
# AUTH_CORS=https://king-keys-storefront.up.railway.app,https://king-keys-backend.up.railway.app

# --- Secrets (REQUIRED - change before deploying!) ---
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECRET=change-me-too-to-a-long-random-string

# --- Database ---
# Local (docker-compose):
DATABASE_URL=postgres://medusa:medusa@localhost:5432/medusa
# Railway automatically provides DATABASE_URL when you attach PostgreSQL plugin.

# --- Redis (optional but recommended) ---
# Local (docker-compose):
REDIS_URL=redis://localhost:6379
# Railway provides REDIS_URL when you attach Redis plugin.

# --- Admin User (auto-created on first boot by init-backend) ---
MEDUSA_ADMIN_EMAIL=admin@kingkeys.com
MEDUSA_ADMIN_PASSWORD=ChangeThisPassword123!

# --- Backend Public URL (used by admin dashboard) ---
# Local:
BACKEND_PUBLIC_URL=http://localhost:9000
# Railway: leave empty — the Railway variable RAILWAY_PUBLIC_DOMAIN_VALUE is used automatically.

# --- Worker Mode (shared | server | worker) ---
MEDUSA_WORKER_MODE=shared

# --- Disable Admin (true = no /app route, useful for worker-only instances) ---
MEDUSA_DISABLE_ADMIN=false

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================

# --- Stripe ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email: Resend (recommended) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@kingkeys.com

# --- Email: SendGrid (alternative) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# --- File Storage: MinIO / S3-compatible ---
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=medusa-media

# --- Meilisearch (optional) ---
MEILISEARCH_HOST=
MEILISEARCH_ADMIN_KEY=

# --- Custom MedusaJS Payment module (optional) ---
MEDUSAJS_PAYMENT_API_KEY=
